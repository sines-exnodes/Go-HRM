# Binaries
/bin/
/tmp/
/server
*.exe
*.test
*.out

# Env
.env
.env.local
.env.*.local

# OS / IDE
.DS_Store
.idea/
.vscode/
*.swp

# Go
vendor/
coverage.out
coverage.html
.air-tmp/

# Swagger generated artifacts kept under docs/swagger only; ignore other generated dirs
/docs/swagger/swagger.json.bak

# Serena MCP — per-developer state. project.yml, memories/, and the LSP
# cache are all machine-local and managed by Serena itself. Each developer
# initialises their own Serena project on first activate.
.serena/

# Claude Code local state — agent memory + per-machine settings.
.claude/

# MCP — per-developer MCP server config. May contain personal API tokens
# (Figma, etc.); never commit. Share project-wide MCP defaults via README.
.mcp.json

# oh-my-claudecode — local session state + project-memory cache.
.omc/
# Claude Code local overrides
.claude/settings.local.json
.claude/.cache/
# Serena local cache
.serena/.cache/
# Backup folder from scaffold edit-mode (safe to delete after review)
.ennam-scaffold-backup/

# Local runtime, credentials, and large backup artifacts
/.codex-pr/
/secret/
/server.err
/server.log
/bk.zip
/Go-HRM.rar

# Checkpoints are committed by default. Uncomment to ignore:
# .serena/checkpoint/
