        "github_com_exnodes_hrm-api_internal_dto.Response-github_com_exnodes_hrm-api_internal_dto_LogoutResponse": {
            "type": "object",
            "properties": {
                "data": {
                    "$ref": "#/definitions/github_com_exnodes_hrm-api_internal_dto.LogoutResponse"
                },
                "message": {
                    "type": "string"
                },
                "success": {
                    "type": "boolean"
                }
            }
        },
        "github_com_exnodes_hrm-api_internal_dto.Response-internal_handlers_HealthData": {
            "type": "object",
            "properties": {
