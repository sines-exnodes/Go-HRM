                    "type": "boolean"
                }
            }
        },
        "github_com_exnodes_hrm-api_internal_dto.Response-array_github_com_exnodes_hrm-api_internal_permissions_PermissionGroup": {
            "type": "object",
            "properties": {
                "data": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/github_com_exnodes_hrm-api_internal_permissions.PermissionGroup"
