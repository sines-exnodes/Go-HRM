# Template for `cp .env.docker.example .env` when deploying with Docker.
# Differences vs the bare-metal .env.example:
#   * DB_HOST=postgres (compose service name, not localhost)
#   * APP_ENV=production, GIN_MODE=release, SWAGGER_ENABLED=false defaults
#   * Reminders on which secrets MUST be replaced before deploy

# ---------- Server ----------
APP_ENV=production
PORT=8080
GIN_MODE=release
SWAGGER_ENABLED=false

# Comma-separated allowed origins. EMPTY value in production = boot refusal.
CORS_ALLOWED_ORIGINS=https://app.exnodes.vn

# ---------- Database ----------
# DB_HOST=postgres resolves to the postgres service inside the compose network.
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE-ME-strong-db-password
DB_NAME=exnodes_hrm
DB_SSLMODE=disable

# Leave DATABASE_URL empty — entrypoint.sh builds it from DB_* above.
DATABASE_URL=

# ---------- Migrations ----------
MIGRATIONS_DIR=migrations

# ---------- Auth ----------
JWT_SECRET_KEY=CHANGE-ME-32-bytes-minimum-for-production-use
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=14

# ---------- Seed ----------
SUPER_ADMIN_EMAIL=admin@exnodes.vn
SUPER_ADMIN_PASSWORD=CHANGE-ME-strong-admin-password
SUPER_ADMIN_NAME=Super Admin

# ---------- AWS S3 Storage ----------
# Bucket must exist and allow public reads for returned avatar/file URLs.
STORAGE_ACCESS_KEY=replace-me
STORAGE_SECRET_KEY=replace-me
STORAGE_REGION=ap-southeast-1
STORAGE_BUCKET=devshared-ap-southeast-1-public-storage

# ---------- Attendance ----------
COMPANY_TIMEZONE=Asia/Ho_Chi_Minh
LATE_THRESHOLD_HOUR=9
LATE_THRESHOLD_MINUTE=0
CHECKOUT_THRESHOLD_HOUR=18
CHECKOUT_THRESHOLD_MINUTE=0
OFFICE_GPS_ENABLED=false
OFFICE_LATITUDE=0.0
OFFICE_LONGITUDE=0.0
OFFICE_RADIUS_METERS=50.0
HALF_DAY_HOURS_THRESHOLD=4.0

# ---------- Email + Invite + Push ----------
APP_NAME=Exnodes HRM
FRONTEND_URL=https://app.exnodes.vn
INVITE_TOKEN_EXPIRE_HOURS=72

# SMTP — leave SMTP_HOST empty to disable email send (invites still log).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@exnodes.vn
SMTP_FROM_NAME=Exnodes HRM
SMTP_USE_TLS=true

# Firebase — leave empty to disable push.
FIREBASE_CREDENTIALS_PATH=
FIREBASE_PROJECT_ID=
