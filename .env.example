# ---------- Server ----------
APP_ENV=development
PORT=8080
GIN_MODE=debug
SWAGGER_ENABLED=true

# Comma-separated list of allowed CORS origins (e.g. https://app.exnodes.vn,https://admin.exnodes.vn).
# Empty is permitted only when APP_ENV=development (falls back to "*"); in production
# an empty value is a fatal misconfiguration and the server refuses to start.
CORS_ALLOWED_ORIGINS=

# ---------- Database ----------
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=exnodes_hrm
DB_SSLMODE=disable

# Full DSN (overrides the DB_* parts above if set). Used by golang-migrate CLI too.
# postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=

# ---------- Migrations ----------
MIGRATIONS_DIR=migrations

# ---------- Auth ----------
JWT_SECRET_KEY=change-me-please-32-bytes-minimum
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=14

# Brute-force protection on /auth/login. After MAX_FAILED_LOGIN_ATTEMPTS
# consecutive bad passwords the account is locked for ACCOUNT_LOCKOUT_MINUTES;
# during that window every login attempt (including the correct one) returns
# 401 "Account temporarily locked. Try again in N minutes." Set MAX_FAILED_LOGIN_ATTEMPTS=0
# to disable the lockout entirely (not recommended).
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15

# Refresh-token TTL when the client sets remember_me=true on /auth/login.
# Falls back to JWT_REFRESH_TTL_DAYS when unset.
REMEMBER_ME_REFRESH_TOKEN_EXPIRE_DAYS=30

# ---------- Seed ----------
SUPER_ADMIN_EMAIL=admin@exnodes.vn
SUPER_ADMIN_PASSWORD=ChangeMe!2026
SUPER_ADMIN_NAME=Super Admin

# ---------- Storage (Supabase S3-compatible — used by avatar/upload module) ----------
# These STORAGE_* keys are the ones the app actually reads (internal/config/storage.go).
# Endpoint is the Supabase project's S3 endpoint; bucket must exist; keys from the
# Supabase dashboard (Storage > S3 connection). Required for any avatar/file upload.
STORAGE_ENDPOINT=https://your-project-ref.storage.supabase.co/storage/v1/s3
STORAGE_ACCESS_KEY=replace-me
STORAGE_SECRET_KEY=replace-me
STORAGE_REGION=us-east-1
STORAGE_BUCKET=hrm-uploads

# ---------- Attendance (Phase 6) ----------
# Late detection compares the first check-in of the day (in COMPANY_TIMEZONE)
# against LATE_THRESHOLD_HOUR:LATE_THRESHOLD_MINUTE. CHECKOUT_* mirror the
# early-leave threshold used by the monthly matrix. GPS validation only fires
# when OFFICE_GPS_ENABLED=true; otherwise the lat/long/radius are ignored.
# HALF_DAY_HOURS_THRESHOLD flips the row's is_half_day flag at check-out time
# when total hours-worked is below this number.
COMPANY_TIMEZONE=Asia/Ho_Chi_Minh
LATE_THRESHOLD_HOUR=9
LATE_THRESHOLD_MINUTE=0
CHECKOUT_THRESHOLD_HOUR=18
CHECKOUT_THRESHOLD_MINUTE=0
OFFICE_GPS_ENABLED=false
OFFICE_LATITUDE=0.0
OFFICE_LONGITUDE=0.0
OFFICE_RADIUS_METERS=50.0
HALF_DAY_HOURS_THRESHOLD=4.0

# ---------- Email + Invite + Push (Phase 9) ----------
APP_NAME=Exnodes HRM
FRONTEND_URL=http://localhost:3000
INVITE_TOKEN_EXPIRE_HOURS=72

# SMTP — point at Mailpit for local dev:
#   docker run -d --rm -p 11025:1025 -p 18025:8025 --name mailpit-phase09 axllent/mailpit
# When SMTP_HOST is empty, the EmailService logs the would-be email and
# writes last_email_error onto the invite row — invite creation still
# succeeds (per Phase 9 REVISION NOTES #11).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@exnodes.local
SMTP_FROM_NAME=Exnodes HRM
SMTP_USE_TLS=false

# Firebase Cloud Messaging — leave empty to disable push in dev. Empty
# credentials path = PushClient becomes a no-op logger.
FIREBASE_CREDENTIALS_PATH=
FIREBASE_PROJECT_ID=
